#!/usr/bin/env bash
set -euo pipefail

export PATH="/etc/profiles/per-user/sudiproy/bin:$HOME/.nix-profile/bin:/run/current-system/sw/bin:/usr/bin:/bin"

if [[ "$(uname)" == "Darwin" ]]; then
  PROFILE="${ZEN_PROFILE:-$HOME/Library/Application Support/Zen/Profiles/sudiproy}"
else
  PROFILE="${ZEN_PROFILE:-$HOME/.config/zen/love}"
fi

BACKUP_DIR="${ZEN_BACKUP_DIR:-$HOME/backup}"
ARCHIVE="$BACKUP_DIR/zen-profile.tar.zst"

mkdir -p "$BACKUP_DIR"
rm -f "$ARCHIVE"

if [ ! -d "$PROFILE" ]; then
  echo "Profile folder not found: $PROFILE"
  exit 1
fi

echo "Archiving Zen profile from $PROFILE..."
tar -cf - -C "$(dirname "$PROFILE")" "$(basename "$PROFILE")" | zstd -3 -f -o "$ARCHIVE"
echo "Done"
ls -lh "$ARCHIVE"
