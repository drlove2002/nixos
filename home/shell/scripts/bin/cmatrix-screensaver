#!/usr/bin/env bash
# Auto cmatrix screensaver — called by hypridle on idle timeout.
# DIMS monitor via DDC/CI, launches cmatrix in background.
# hypridle's on-resume handles restore + kill.

# Save RGB state and turn off all lights
openrgb -s /tmp/cmatrix-rgb.orp 2>/dev/null
openrgb --mode off 2>/dev/null

# Save current brightness and dim
ddcutil getvcp 10 --brief 2>/dev/null | cut -d' ' -f4 > /tmp/cmatrix-brightness
ddcutil setvcp 10 0 2>/dev/null

# Kill any stale instance and launch
pkill -f "kitty.*cmatrix-screensaver" 2>/dev/null
sleep 0.1
kitty \
  --class cmatrix-screensaver \
  --title cmatrix-screensaver \
  -o background_opacity=0.8 \
  -o window_padding_width=0 \
  cmatrix -s -b -a -u 2 -C green &
