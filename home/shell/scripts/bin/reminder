#!/usr/bin/env bash
# reminder — schedule popup reminders with sound + notification
#
# Usage:
#   reminder <time>... <message>
#   reminder -l | --list
#   reminder -c | --cancel <id>
#   reminder -C | --cancel-all
#
# Examples:
#   reminder 45m 10s It's time to drink water
#   reminder 1h 30m Stand up and stretch
#   reminder 10s Quick test

set -euo pipefail

DIR="${XDG_RUNTIME_DIR:-/tmp}/reminder"
PIDS="$DIR/pids"
SOUND="$DIR/alarm.wav"

mkdir -p "$PIDS"

# ── Helpers ──────────────────────────────────────────────────────────

die()  { echo "reminder: $*" >&2; exit 1; }

fmt() {
    local t=$1 out=""
    ((t >= 3600)) && out+="$((t / 3600))h " && t=$((t % 3600))
    ((t >= 60))   && out+="$((t / 60))m "   && t=$((t % 60))
    ((t > 0))     && out+="${t}s"
    echo "${out:-0s}" | xargs
}

# ── Sound generation (cached) ───────────────────────────────────────

gen_alarm() {
    [[ -f "$SOUND" ]] && return
    command -v ffmpeg &>/dev/null || return

    # Harsh dual-tone alarm: 880Hz + 1760Hz, hard-clipped, fast beeps
    # Uses volume envelope to gate a continuous sine into a beep pattern
    ffmpeg -y -loglevel error \
        -f lavfi -i "sine=f=880:d=3" \
        -f lavfi -i "sine=f=1760:d=3" \
        -filter_complex "
            [0][1]amix=inputs=2:duration=shortest,
            volume=6,
            volume='if(lt(mod(t,0.25),0.15),1,0)':eval=frame
        " -c:a pcm_s16le "$SOUND"
}

# ── Audio playback (best available) ─────────────────────────────────

play_sound() {
    [[ -f "$SOUND" ]] || return 0

    # pw-play:  PipeWire native, lowest overhead
    # paplay:   PulseAudio (works on PipeWire via pipewire-pulse too)
    # aplay:    ALSA direct, no daemon needed
    # mpv:      heavy but universal
    if   command -v pw-play &>/dev/null; then pw-play "$SOUND"
    elif command -v paplay  &>/dev/null; then paplay  "$SOUND"
    elif command -v aplay   &>/dev/null; then aplay   "$SOUND"
    elif command -v mpv     &>/dev/null; then mpv --no-video --really-quiet "$SOUND"
    fi
}

# ── Notify ───────────────────────────────────────────────────────────

notify() {
    local msg="$1"

    # Sound and notification in parallel — don't let one block the other
    play_sound &
    notify-send -u critical -a Reminder -i alarm-symbolic \
        "⏰ Reminder" "$msg"
    wait
}

# ── List / Cancel ────────────────────────────────────────────────────

list_reminders() {
    local found=false now
    now=$(date +%s)

    for f in "$PIDS"/*.pid; do
        [[ -f "$f" ]] || continue
        IFS='|' read -r pid msg fire_at < "$f"
        if kill -0 "$pid" 2>/dev/null; then
            local rem=$(( fire_at - now ))
            ((rem < 0)) && rem=0
            printf "  [%s]  in %-8s  %s\n" "$(basename "$f" .pid)" "$(fmt $rem)" "$msg"
            found=true
        else
            rm -f "$f"
        fi
    done
    $found || echo "  No active reminders."
}

cancel() {
    local f="$PIDS/$1.pid"
    [[ -f "$f" ]] || die "no reminder '$1' — use --list"
    IFS='|' read -r pid _ _ < "$f"
    kill "$pid" 2>/dev/null && echo "Cancelled [$1]." || echo "[$1] already finished."
    rm -f "$f"
}

cancel_all() {
    local n=0
    for f in "$PIDS"/*.pid; do
        [[ -f "$f" ]] || continue
        IFS='|' read -r pid _ _ < "$f"
        kill "$pid" 2>/dev/null || :
        rm -f "$f"
        ((n++))
    done
    echo "Cancelled $n reminder(s)."
}

# ── Parse args ───────────────────────────────────────────────────────

(( $# )) || die "usage: reminder <time>... <message>  (try --help)"

case "$1" in
    -h|--help)
        sed -n '2,/^[^#]/{ s/^# \?//p; }' "$0"; exit 0 ;;
    -l|--list)       list_reminders; exit 0 ;;
    -c|--cancel)     cancel "${2:?id required}"; exit 0 ;;
    -C|--cancel-all) cancel_all; exit 0 ;;
esac

secs=0
got_time=false
msg_start=0

for (( i=1; i<=$#; i++ )); do
    arg="${!i}"
    if [[ "$arg" =~ ^([0-9]+)(s|m|h)$ ]]; then
        v="${BASH_REMATCH[1]}"
        case "${BASH_REMATCH[2]}" in
            s) secs=$((secs + v)) ;;
            m) secs=$((secs + v * 60)) ;;
            h) secs=$((secs + v * 3600)) ;;
        esac
        got_time=true
        msg_start=$((i + 1))
    else
        break
    fi
done

$got_time              || die "no time given (e.g. 45m, 1h 30m, 10s)"
(( msg_start <= $# ))  || die "no message given"

message="${*:$msg_start}"
fire_at=$(( $(date +%s) + secs ))
id=$(head -c4 /dev/urandom | xxd -p)

# Generate alarm sound once (cached at $DIR/alarm.wav)
gen_alarm

# ── Schedule ─────────────────────────────────────────────────────────

(
    sleep "$secs"
    notify "$message"
    rm -f "$PIDS/$id.pid"
) &
disown $!

echo "${!}|${message}|${fire_at}" > "$PIDS/$id.pid"
echo "✓ \"${message}\" in $(fmt $secs) [$id]"
