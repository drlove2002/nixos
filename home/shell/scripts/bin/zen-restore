#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/.nix-profile/bin:/run/current-system/sw/bin:/usr/bin:/bin"

if [[ "$(uname)" == "Darwin" ]]; then
  PROFILE="${ZEN_PROFILE:-$HOME/Library/Application Support/Zen/Profiles/sudiproy}"
else
  PROFILE="${ZEN_PROFILE:-$HOME/.config/zen/love}"
fi

BACKUP_DIR="${ZEN_BACKUP_DIR:-$HOME/backup}"
ARCHIVE="$BACKUP_DIR/zen-profile.tar.zst"

if [ ! -f "$ARCHIVE" ]; then
  echo "No backup archive found at: $ARCHIVE"
  exit 1
fi

if pgrep -x "zen" > /dev/null || pgrep -x "zen-beta" > /dev/null; then
  echo "Zen Browser is running — close it first"
  exit 1
fi

if [ -d "$PROFILE" ]; then
  mv "$PROFILE" "${PROFILE}.bak.$(date +%Y%m%d-%H%M%S)"
  echo "Old profile moved to backup"
fi

mkdir -p "$(dirname "$PROFILE")"
echo "Restoring Zen profile from $ARCHIVE..."
zstd -d -c "$ARCHIVE" | tar -xf - -C "$(dirname "$PROFILE")"
echo "Done"
