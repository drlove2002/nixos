{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "terminal": {
    "shell": "system"
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "deepseek",
      "model": "deepseek-chat",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "auto_install_extensions": {
    "make": true,
    "nix": true,
    "rust": true,
    "toml": true
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "Maple Mono",
  "buffer_font_size": 21.333333333333332,
  "theme": "Base16 Kanagawa",
  "ui_font_family": "Maple Mono",
  "ui_font_size": 16.0,
  "vim_mode": true
}
